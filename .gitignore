# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Rust / Tauri
src-tauri/target/
src-tauri/gen/

# Python sidecar
sidecar/__pycache__/
sidecar/*.pyc
sidecar/dist/
sidecar/build/
sidecar/*.spec

# Sensitive — NEVER commit keys
api_keys.json
*.keys.json
# Tauri updater Ed25519 keypair (must stay out of the repo, even by accident)
*.updater.key
*.updater.key.pub
updater.key
updater.key.pub
# Auto-update manifest is generated per-release in CI, not committed
latest.json

# Playwright MCP debug artifacts
.playwright-mcp/

# Claude Code local settings (settings.local.json, scheduled_tasks.lock)
# but track .claude/agents/*.md (versioned sub-agent definitions shared
# across contributors — see SECURITY.md / docs/security-audits/).
.claude/*
!.claude/agents/
.claude/agents/*
!.claude/agents/*.md
**/.claude/*
!**/.claude/agents/
**/.claude/agents/*
!**/.claude/agents/*.md

# Env
.env
.env.local
.env.*
